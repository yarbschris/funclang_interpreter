let rec is_prime_from n d =
  if d * d > n then true
  else if n % d == 0 then false
  else is_prime_from n (d + 1)
in
let is_prime = fun n ->
  if n < 2 then false else is_prime_from n 2
in
let rec sum_primes_up_to n acc =
  if n < 2 then acc
  else if is_prime n then sum_primes_up_to (n - 1) (acc + n)
  else sum_primes_up_to (n - 1) acc
in
sum_primes_up_to 100 0
